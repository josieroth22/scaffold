{
  "outputDirectory": "src",
  "functions": {
    "api/*.js": {
      "maxDuration": 800
    }
  },
  "crons": [
    {
      "path": "/api/keep-alive",
      "schedule": "0 9 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ]
}
